# Copy to .env.local and adjust values for local development.
APP_NAME=voicesaju
ENVIRONMENT=local
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Datastore connections (docker-compose Postgres + Redis) ---
# Match the service definitions in `docker-compose.yml` at the repo root.
DATABASE_URL=postgresql+asyncpg://voicesaju:voicesaju@localhost:5432/voicesaju
REDIS_URL=redis://localhost:6379/0

# --- KMS envelope encryption (local KEK; ISSUE-009) ---
# Generate via:  python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# DO NOT use the placeholder below in any deployed environment.
LOCAL_KEK_BASE64=REPLACE_WITH_BASE64_32_BYTES
KMS_PROVIDER=local
